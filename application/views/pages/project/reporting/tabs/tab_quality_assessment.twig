<div class="container-fluid">
	{% if is_owner|default(false) %}
		<div class="row justify-content-center mb-4">
			<div class="col-md-10">
				<div class="card shadow-sm">
					<div class="card-body">
						{% for member in data.project.get_members %}
							{% if member.get_level == 'Administrator' or member.get_level == 'Researcher' %}
								{% set member_counts = data.count_papers[member.get_email]|default({}) %}
								{% set total = member_counts[5]|default(0) %}
								{% set acc = total > 0 ? ((member_counts[1]|default(0) * 100) / total)|number_format(2) : 0 %}
								{% set rej = total > 0 ? ((member_counts[2]|default(0) * 100) / total)|number_format(2) : 0 %}
								{% set unc = total > 0 ? ((member_counts[3]|default(0) * 100) / total)|number_format(2) : 0 %}
								{% set rem = total > 0 ? ((member_counts[4]|default(0) * 100) / total)|number_format(2) : 0 %}

								<div class="progress-indicator-container mb-4">
									<div class="d-flex align-items-center justify-content-between flex-wrap mb-2">
										<h5 class="mb-0">{{ member.get_name }}</h5>
										<div class="d-flex flex-wrap gap-1">
											<span class="badge rounded-pill progress-indicator-badge-acc mr-2 mb-2"><i class="fas fa-check mr-1"></i>Accepted: <span>{{ member_counts[1]|default(0) }}</span></span>
											<span class="badge rounded-pill progress-indicator-badge-rej mr-2 mb-2"><i class="fas fa-times mr-1"></i>Rejected: <span>{{ member_counts[2]|default(0) }}</span></span>
											<span class="badge rounded-pill progress-indicator-badge-unc mr-2 mb-2"><i class="fas fa-question mr-1"></i>Unclassified: <span>{{ member_counts[3]|default(0) }}</span></span>
											<span class="badge rounded-pill progress-indicator-badge-rem mr-2 mb-2"><i class="fas fa-trash-alt mr-1"></i>Removed: <span>{{ member_counts[4]|default(0) }}</span></span>
											<span class="badge rounded-pill progress-indicator-badge-total mr-2 mb-2"><i class="fas fa-bars mr-1"></i>Total: <span>{{ member_counts[5]|default(0) }}</span></span>
										</div>
									</div>
									<div class="progress progress-indicator-bar" style="height: 1.5rem;">
										<div class="progress-bar progress-indicator-bar-acc" role="progressbar" style="width: {{ acc }}%" aria-valuenow="{{ acc }}" aria-valuemin="0" aria-valuemax="100">{{ acc }}%</div>
										<div class="progress-bar progress-indicator-bar-rej" role="progressbar" style="width: {{ rej }}%" aria-valuenow="{{ rej }}" aria-valuemin="0" aria-valuemax="100">{{ rej }}%</div>
										<div class="progress-bar progress-indicator-bar-unc" role="progressbar" style="width: {{ unc }}%" aria-valuenow="{{ unc }}" aria-valuemin="0" aria-valuemax="100">{{ unc }}%</div>
										<div class="progress-bar progress-indicator-bar-rem" role="progressbar" style="width: {{ rem }}%" aria-valuenow="{{ rem }}" aria-valuemin="0" aria-valuemax="100">{{ rem }}%</div>
									</div>
								</div>
								<hr>
							{% endif %}
						{% endfor %}

						{% set project_total = data.count_project[5]|default(0) %}
						{% set acc = project_total > 0 ? ((data.count_project[1]|default(0) * 100) / project_total)|number_format(2) : 0 %}
						{% set rej = project_total > 0 ? ((data.count_project[2]|default(0) * 100) / project_total)|number_format(2) : 0 %}
						{% set unc = project_total > 0 ? ((data.count_project[3]|default(0) * 100) / project_total)|number_format(2) : 0 %}
						{% set rem = project_total > 0 ? ((data.count_project[4]|default(0) * 100) / project_total)|number_format(2) : 0 %}

						<div class="progress-indicator-container mb-0">
							<div class="d-flex align-items-center justify-content-between flex-wrap mb-2">
								<h5 class="mb-0">{{ data.project.get_title }}</h5>
								<div class="d-flex flex-wrap gap-1">
									<span class="badge rounded-pill progress-indicator-badge-acc mr-2 mb-2"><i class="fas fa-check mr-1"></i>Accepted: <span id="count_acc_qa">{{ data.count_project[1]|default(0) }}</span></span>
									<span class="badge rounded-pill progress-indicator-badge-rej mr-2 mb-2"><i class="fas fa-times mr-1"></i>Rejected: <span id="count_rej_qa">{{ data.count_project[2]|default(0) }}</span></span>
									<span class="badge rounded-pill progress-indicator-badge-unc mr-2 mb-2"><i class="fas fa-question mr-1"></i>Unclassified: <span id="count_unc_qa">{{ data.count_project[3]|default(0) }}</span></span>
									<span class="badge rounded-pill progress-indicator-badge-rem mr-2 mb-2"><i class="fas fa-trash-alt mr-1"></i>Removed: <span id="count_rem_qa">{{ data.count_project[4]|default(0) }}</span></span>
									<span class="badge rounded-pill progress-indicator-badge-total mr-2 mb-2"><i class="fas fa-bars mr-1"></i>Total: <span id="count_total_qa">{{ data.count_project[5]|default(0) }}</span></span>
								</div>
							</div>
							<div class="progress progress-indicator-bar" style="height: 1.5rem;">
								<div id="prog_acc_qa" class="progress-bar progress-indicator-bar-acc" role="progressbar" style="width: {{ acc }}%" aria-valuenow="{{ acc }}" aria-valuemin="0" aria-valuemax="100">{{ acc }}%</div>
								<div id="prog_rej_qa" class="progress-bar progress-indicator-bar-rej" role="progressbar" style="width: {{ rej }}%" aria-valuenow="{{ rej }}" aria-valuemin="0" aria-valuemax="100">{{ rej }}%</div>
								<div id="prog_unc_qa" class="progress-bar progress-indicator-bar-unc" role="progressbar" style="width: {{ unc }}%" aria-valuenow="{{ unc }}" aria-valuemin="0" aria-valuemax="100">{{ unc }}%</div>
								<div id="prog_rem_qa" class="progress-bar progress-indicator-bar-rem" role="progressbar" style="width: {{ rem }}%" aria-valuenow="{{ rem }}" aria-valuemin="0" aria-valuemax="100">{{ rem }}%</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="row justify-content-center mb-4">
			<div class="col-md-10">
				<div class="card shadow-sm">
					<div class="card-body">
						<table class="table table-responsive-sm" id="table_papers_quality_rep">
							<caption>List of Papers for Quality Assessment</caption>
							<thead>
							<tr>
								<th>ID</th>
								<th>Title</th>
								{% for qa in data.project.get_questions_quality %}
									<th>{{ qa.get_id }}</th>
								{% endfor %}
								<th>General Score</th>
								<th>Score</th>
								<th>Status</th>
							</tr>
							</thead>
							<tbody>
							{% for paper in data.papers %}
								{% set qas = data.qas_score[paper.get_id]|default({}) %}
								{% set class = 'text-dark' %}
								{% set status = 'Unclassified' %}
								{% if paper.get_status_quality == 1 %}
									{% set class = 'text-success' %}
									{% set status = 'Accepted' %}
								{% elseif paper.get_status_quality == 2 %}
									{% set class = 'text-danger' %}
									{% set status = 'Rejected' %}
								{% elseif paper.get_status_quality == 4 %}
									{% set class = 'text-info' %}
									{% set status = 'Removed' %}
								{% endif %}
								<tr>
									<td>{{ paper.get_id }}</td>
									<td>{{ paper.get_title }}</td>
									{% for qa in data.project.get_questions_quality %}
										<td>{{ qas[qa.get_id]|default('') }}</td>
									{% endfor %}
									<td>{{ paper.get_rule_quality }}</td>
									<td>{{ paper.get_score }}</td>
									<td id="{{ paper.get_id }}" class="font-weight-bold {{ class }}">{{ status }}</td>
								</tr>
							{% endfor %}
							</tbody>
							<tfoot>
							<tr>
								<th>ID</th>
								<th>Title</th>
								{% for qa in data.project.get_questions_quality %}
									<th>{{ qa.get_id }}</th>
								{% endfor %}
								<th>General Score</th>
								<th>Score</th>
								<th>Status</th>
							</tr>
							</tfoot>
						</table>
					</div>
				</div>
			</div>
		</div>
	{% endif %}

	<div class="row g-4">
		<div class="col-md-6">
			<div class="card h-100">
				<div class="card-body">
					<h6 class="mb-3"><strong>Papers per Quality</strong></h6>
					<div id="quality_tab_papers_per_quality"></div>
				</div>
			</div>
		</div>
		<div class="col-md-6">
			<div class="card h-100">
				<div class="card-body">
					<h6 class="mb-3"><strong>General Score</strong></h6>
					<div id="quality_tab_papers_gen_score"></div>
				</div>
			</div>
		</div>
	</div>
</div>

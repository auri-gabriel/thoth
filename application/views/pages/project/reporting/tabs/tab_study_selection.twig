<div class="container-fluid">
	{% if is_owner|default(false) %}
		<div class="row justify-content-center mb-4">
			<div class="col-md-10">
				<div class="card shadow-sm">
					<div class="card-body">
						{% for member in data.project.get_members %}
							{% if member.get_level == 'Administrator' or member.get_level == 'Researcher' %}
								{% set member_counts = data.count_papers_sel[member.get_email]|default({}) %}
								{% set total = member_counts[6]|default(0) %}
								{% set acc = total > 0 ? ((member_counts[1]|default(0) * 100) / total)|number_format(2) : 0 %}
								{% set rej = total > 0 ? ((member_counts[2]|default(0) * 100) / total)|number_format(2) : 0 %}
								{% set unc = total > 0 ? ((member_counts[3]|default(0) * 100) / total)|number_format(2) : 0 %}
								{% set dup = total > 0 ? ((member_counts[4]|default(0) * 100) / total)|number_format(2) : 0 %}
								{% set rem = total > 0 ? ((member_counts[5]|default(0) * 100) / total)|number_format(2) : 0 %}

								<div class="progress-indicator-container mb-4">
									<div class="d-flex align-items-center justify-content-between flex-wrap mb-2">
										<h5 class="mb-0">{{ member.get_name }}</h5>
										<div class="d-flex flex-wrap gap-1">
											<span class="badge rounded-pill progress-indicator-badge-acc mr-2 mb-2"><i class="fas fa-check mr-1"></i>Accepted: <span>{{ member_counts[1]|default(0) }}</span></span>
											<span class="badge rounded-pill progress-indicator-badge-rej mr-2 mb-2"><i class="fas fa-times mr-1"></i>Rejected: <span>{{ member_counts[2]|default(0) }}</span></span>
											<span class="badge rounded-pill progress-indicator-badge-unc mr-2 mb-2"><i class="fas fa-question mr-1"></i>Unclassified: <span>{{ member_counts[3]|default(0) }}</span></span>
											<span class="badge rounded-pill progress-indicator-badge-dup mr-2 mb-2"><i class="fas fa-copy mr-1"></i>Duplicate: <span>{{ member_counts[4]|default(0) }}</span></span>
											<span class="badge rounded-pill progress-indicator-badge-rem mr-2 mb-2"><i class="fas fa-trash-alt mr-1"></i>Removed: <span>{{ member_counts[5]|default(0) }}</span></span>
											<span class="badge rounded-pill progress-indicator-badge-total mr-2 mb-2"><i class="fas fa-bars mr-1"></i>Total: <span>{{ member_counts[6]|default(0) }}</span></span>
										</div>
									</div>
									<div class="progress progress-indicator-bar" style="height: 1.5rem;">
										<div class="progress-bar progress-indicator-bar-acc" role="progressbar" style="width: {{ acc }}%" aria-valuenow="{{ acc }}" aria-valuemin="0" aria-valuemax="100">{{ acc }}%</div>
										<div class="progress-bar progress-indicator-bar-rej" role="progressbar" style="width: {{ rej }}%" aria-valuenow="{{ rej }}" aria-valuemin="0" aria-valuemax="100">{{ rej }}%</div>
										<div class="progress-bar progress-indicator-bar-unc" role="progressbar" style="width: {{ unc }}%" aria-valuenow="{{ unc }}" aria-valuemin="0" aria-valuemax="100">{{ unc }}%</div>
										<div class="progress-bar progress-indicator-bar-dup" role="progressbar" style="width: {{ dup }}%" aria-valuenow="{{ dup }}" aria-valuemin="0" aria-valuemax="100">{{ dup }}%</div>
										<div class="progress-bar progress-indicator-bar-rem" role="progressbar" style="width: {{ rem }}%" aria-valuenow="{{ rem }}" aria-valuemin="0" aria-valuemax="100">{{ rem }}%</div>
									</div>
								</div>
								<hr>
							{% endif %}
						{% endfor %}

						{% set project_total = data.count_project_sel[6]|default(0) %}
						{% set acc = project_total > 0 ? ((data.count_project_sel[1]|default(0) * 100) / project_total)|number_format(2) : 0 %}
						{% set rej = project_total > 0 ? ((data.count_project_sel[2]|default(0) * 100) / project_total)|number_format(2) : 0 %}
						{% set unc = project_total > 0 ? ((data.count_project_sel[3]|default(0) * 100) / project_total)|number_format(2) : 0 %}
						{% set dup = project_total > 0 ? ((data.count_project_sel[4]|default(0) * 100) / project_total)|number_format(2) : 0 %}
						{% set rem = project_total > 0 ? ((data.count_project_sel[5]|default(0) * 100) / project_total)|number_format(2) : 0 %}

						<div class="progress-indicator-container mb-0">
							<div class="d-flex align-items-center justify-content-between flex-wrap mb-2">
								<h5 class="mb-0">{{ data.project.get_title }}</h5>
								<div class="d-flex flex-wrap gap-1">
									<span class="badge rounded-pill progress-indicator-badge-acc mr-2 mb-2"><i class="fas fa-check mr-1"></i>Accepted: <span id="count_acc">{{ data.count_project_sel[1]|default(0) }}</span></span>
									<span class="badge rounded-pill progress-indicator-badge-rej mr-2 mb-2"><i class="fas fa-times mr-1"></i>Rejected: <span id="count_rej">{{ data.count_project_sel[2]|default(0) }}</span></span>
									<span class="badge rounded-pill progress-indicator-badge-unc mr-2 mb-2"><i class="fas fa-question mr-1"></i>Unclassified: <span id="count_unc">{{ data.count_project_sel[3]|default(0) }}</span></span>
									<span class="badge rounded-pill progress-indicator-badge-dup mr-2 mb-2"><i class="fas fa-copy mr-1"></i>Duplicate: <span id="count_dup">{{ data.count_project_sel[4]|default(0) }}</span></span>
									<span class="badge rounded-pill progress-indicator-badge-rem mr-2 mb-2"><i class="fas fa-trash-alt mr-1"></i>Removed: <span id="count_rem">{{ data.count_project_sel[5]|default(0) }}</span></span>
									<span class="badge rounded-pill progress-indicator-badge-total mr-2 mb-2"><i class="fas fa-bars mr-1"></i>Total: <span id="count_total">{{ data.count_project_sel[6]|default(0) }}</span></span>
								</div>
							</div>
							<div class="progress progress-indicator-bar" style="height: 1.5rem;">
								<div id="prog_acc" class="progress-bar progress-indicator-bar-acc" role="progressbar" style="width: {{ acc }}%" aria-valuenow="{{ acc }}" aria-valuemin="0" aria-valuemax="100">{{ acc }}%</div>
								<div id="prog_rej" class="progress-bar progress-indicator-bar-rej" role="progressbar" style="width: {{ rej }}%" aria-valuenow="{{ rej }}" aria-valuemin="0" aria-valuemax="100">{{ rej }}%</div>
								<div id="prog_unc" class="progress-bar progress-indicator-bar-unc" role="progressbar" style="width: {{ unc }}%" aria-valuenow="{{ unc }}" aria-valuemin="0" aria-valuemax="100">{{ unc }}%</div>
								<div id="prog_dup" class="progress-bar progress-indicator-bar-dup" role="progressbar" style="width: {{ dup }}%" aria-valuenow="{{ dup }}" aria-valuemin="0" aria-valuemax="100">{{ dup }}%</div>
								<div id="prog_rem" class="progress-bar progress-indicator-bar-rem" role="progressbar" style="width: {{ rem }}%" aria-valuenow="{{ rem }}" aria-valuemin="0" aria-valuemax="100">{{ rem }}%</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	{% endif %}

	<div class="row justify-content-center">
		<div class="col-md-10">
			<div class="card shadow-sm">
				<div class="card-body">
					<h6 class="mb-3"><strong>Papers per Selection</strong></h6>
					<div id="selection_tab_papers_per_selection"></div>
				</div>
			</div>
		</div>
	</div>
</div>
